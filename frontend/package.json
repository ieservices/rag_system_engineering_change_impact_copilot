{
  "name": "engineering-change-impact-copilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "run:fully_containerized": "podman-compose -f ../docker-compose.yml up -d --build",
    "run:local_fe__containerized_be_and_db": "podman-compose -f ../docker-compose.dev.yml up -d --build && vite",
    "run:local_fe_be__containerized_db": "podman-compose -f ../docker-compose.db.yml up -d",
    "stop": "podman-compose -f ../docker-compose.yml down & podman-compose -f ../docker-compose.dev.yml down & podman-compose -f ../docker-compose.db.yml down",
    "logs:backend": "podman logs -f impact-copilot-backend"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "axios": "^1.6.7",
    "@vueuse/core": "^10.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.1.4",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  }
}
