{
    "esversion": 11,
    "module": true,
    "strict": "implied",
    "asi": false,
    "boss": false,
    "debug": false,
    "eqeqeq": true,
    "eqnull": false,
    "evil": false,
    "forin": true,
    "funcscope": false,
    "iterator": false,
    "latedef": "nofunc",
    "loopfunc": false,
    "noarg": true,
    "nocomma": true,
    "nonbsp": true,
    "nonew": true,
    "notypeof": false,
    "proto": false,
    "scripturl": false,
    "shadow": false,
    "singleGroups": false,
    "sub": false,
    "supernew": false,
    "undef": true,
    "unused": true,
    "varstmt": false,
    "browser": true,
    "node": true,
    "globals": {
        "console": true,
        "module": true,
        "require": true,
        "process": true
    }
}
